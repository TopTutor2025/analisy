# Copia questo file in .env e modifica i valori

# Porta del server (Railway la imposta automaticamente)
PORT=3000

# Chiave segreta per i token JWT — CAMBIA QUESTO IN PRODUZIONE con una stringa lunga e casuale
JWT_SECRET=cambia-questa-chiave-con-qualcosa-di-lungo-e-casuale

# Percorso del database SQLite
# In locale: lascia vuoto (usa db/analisy.db)
# Su Railway: imposta su /data/analisy.db e aggiungi un Volume montato su /data
DB_PATH=
